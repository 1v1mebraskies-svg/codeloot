{
  "rewrites": [
    {
      "source": "/",
      "destination": "/admin-index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/admin-index.html"
    }
  ]
}
