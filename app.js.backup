js
(function () {
    const siteRoot = document.body.dataset.siteRoot || ".";

    function gameUrl(fileName) {
        return `${siteRoot}/games/${fileName}`;
    }

    function setupSearch() {
        const searchForms = document.querySelectorAll("[data-site-search]");
        const emptyState = document.querySelector("[data-search-empty]");

        /**
         * Extract all searchable text from a game card
         * Dynamically builds searchable content from card elements
         */
        function getSearchableText(card) {
            // Get game name from data attribute
            const gameName = (card.dataset.gameName || "").toLowerCase();
            
            // Get title from h3
            const cardTitle = card.querySelector("h3")?.textContent || "";
            
            // Get description from p tags
            const cardDesc = card.querySelector("p")?.textContent || "";
            
            // Get metadata (count info, rewards, etc.)
            const cardMeta = card.querySelector(".card-meta")?.textContent || "";
            
            // Get image alt text (often contains game descriptions)
            const imgAlt = card.querySelector("img")?.alt || "";
            
            // Get any link text
            const linkText = card.querySelector(".text-link")?.textContent || "";
            
            // Combine all searchable content
            const allText = `${gameName} ${cardTitle} ${cardDesc} ${cardMeta} ${imgAlt} ${linkText}`;
            
            return allText.toLowerCase();
        }

        /**
         * Get all game cards on the page
         * This is dynamic - newly added cards will be found automatically
         */
        function getAllGameCards() {
            return document.querySelectorAll("[data-game-card]");
        }

        /**
         * Update the datalist with current games
         * This helps with autocomplete suggestions
         */
        function updateGameList() {
            const gameList = document.querySelector("#game-list");
            if (!gameList) return;

            // Clear existing options
            gameList.innerHTML = "";

            // Get all game cards and extract unique game names
            const gameNames = new Set();
            getAllGameCards().forEach(function (card) {
                const gameName = card.dataset.gameName;
                if (gameName) {
                    gameNames.add(gameName);
                }
            });

            // Add options to datalist
            gameNames.forEach(function (name) {
                const option = document.createElement("option");
                option.value = name;
                gameList.appendChild(option);
            });
        }

        /**
         * Filter game cards based on search query
         * Returns count of visible cards
         */
        function filterCards(query) {
            const gameCards = getAllGameCards();
            let visibleCount = 0;

            gameCards.forEach(function (card) {
                const searchableText = getSearchableText(card);
                
                // Check if search query matches any part of the searchable text
                // Empty query shows all cards
                const isVisible = !query || searchableText.includes(query);

                // Apply or remove hidden class
                card.classList.toggle("is-hidden", !isVisible);

                if (isVisible) {
                    visibleCount += 1;
                }
            });

            return visibleCount;
        }

        // Setup search functionality for each search form
        searchForms.forEach(function (form) {
            const input = form.querySelector("[data-game-search]");

            if (!input) {
                return;
            }

            // Update game list when page loads
            updateGameList();

            /**
             * Handle search input - live filtering
             */
            input.addEventListener("input", function () {
                const query = input.value.trim().toLowerCase();
                const visibleCount = filterCards(query);

                // Show empty state if no results and query is not empty
                if (emptyState) {
                    emptyState.hidden = visibleCount !== 0 || !query;
                }
            });

            /**
             * Handle form submission - navigate to first matching game
             */
            form.addEventListener("submit", function (event) {
                event.preventDefault();

                const query = input.value.trim().toLowerCase();
                if (!query) return;

                const gameCards = getAllGameCards();
                let foundCard = null;

                // Find first visible (matching) card
                for (let i = 0; i < gameCards.length; i++) {
                    const card = gameCards[i];
                    const searchableText = getSearchableText(card);

                    if (searchableText.includes(query)) {
                        foundCard = card;
                        break;
                    }
                }

                // Navigate to game page if found
                if (foundCard) {
                    window.location.href = foundCard.href;
                }
            });

            /**
             * Clear search on input focus with Escape key
             */
            input.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    input.value = "";
                    filterCards("");
                    if (emptyState) {
                        emptyState.hidden = true;
                    }
                }
            });
        });
    }

    function fallbackCopy(text) {
        return new Promise(function (resolve) {
            const helper = document.createElement("textarea");

            helper.value = text;
            helper.className = "clipboard-helper";

            document.body.appendChild(helper);
            helper.select();
            document.execCommand("copy");
            helper.remove();

            resolve();
        });
    }

    function copyWithFallback(text) {
        if (navigator.clipboard && window.isSecureContext) {
            return navigator.clipboard.writeText(text).catch(function () {
                return fallbackCopy(text);
            });
        }

        return fallbackCopy(text);
    }

    function setupCopyButtons() {
        const copyButtons = document.querySelectorAll("[data-code]");

        copyButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                const code = button.dataset.code;
                const defaultText = button.dataset.defaultText || button.textContent;

                copyWithFallback(code).then(function () {
                    button.textContent = "Copied";
                    button.classList.add("is-copied");

                    window.setTimeout(function () {
                        button.textContent = defaultText;
                        button.classList.remove("is-copied");
                    }, 1400);
                });
            });
        });
    }

    function setupContactForm() {
        const contactForm = document.getElementById("contact-form");

        if (!contactForm) {
            return;
        }

        contactForm.addEventListener("submit", function (event) {
            event.preventDefault();

            const name = contactForm.querySelector("#name").value.trim();
            const email = contactForm.querySelector("#email").value.trim();
            const subject = contactForm.querySelector("#subject").value.trim();
            const message = contactForm.querySelector("#message").value.trim();

            if (!name || !email || !subject || !message) {
                alert("Please fill in all fields.");
                return;
            }

            const mailtoLink = "mailto:hello@codeloot.codes?subject=" + 
                encodeURIComponent("[CodeLoot Contact] " + subject) +
                "&body=" + 
                encodeURIComponent("Name: " + name + "\nEmail: " + email + "\n\nMessage:\n" + message);

            window.location.href = mailtoLink;
        });
    }

    setupSearch();
    setupCopyButtons();
    setupContactForm();
}());